            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "",
                  "pm.test('Response has expected fields', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('account_id');",
                  "    pm.expect(json).to.have.property('document_number');",
                  "    pm.expect(json.is_active).to.be.true;",
                  "});",
                  "",
                  "// Save account_id for use in downstream requests.",
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('accountId', pm.response.json().account_id);",
                  "}"
                ]
              }
            }
